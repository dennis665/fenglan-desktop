# =========================================================================
# 2D 桌面魔法寵物 (Desktop Mascot) - Git 忽略設定檔 (.gitignore)
# =========================================================================

# Node.js 依賴套件
node_modules/

# 本地環境設定檔（包含敏感密碼與本地開關）
.env

# 日誌日誌與偵錯日誌
*.log
logs/

# Electron 打包與編譯輸出資料夾
dist/
dist-packager/

# 系統快取臨時檔案
.DS_Store
Thumbs.db

# =========================================================================
# 🚫 排除自訂上傳的影音資料夾 (不提交至 GitHub)
# =========================================================================
# 忽略自訂影音資料夾 (因為影片與音樂檔案較大，不適合推上 GitHub)
assets/media/

# 忽略自訂影音播放清單數據 (個人歌單設定)
assets/custom_media.json
